@page
@model StudentsManager.Mvc.Pages.SecondExaminationModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
}
@if (Model.Enabled)
{
    <div class="total-wrap-content">
        <div class="login-section">
            <div class="main-inner-content-wrap anim-block">
                <div class="login-title-wrap anim-elem top">
                    <h2 class="title-big">Второ контролно</h2>
                    <p class="p-large">
                        <a href="@Model.ExaminationResourceUrl" target="_blank">Този линк</a> ще те заведе до задачите,
                        <a href="@Model.ExaminationExtraResourceUrl" target="_blank">а този</a> до ресурсите.
                    </p>
                </div>
                <div class="login-grid">
                    <div class="login-grid-wrap">
                        <div class="login-content-item anim-elem top">
                            <div class="login-content-item-wrap">
                                <form method="post" enctype="multipart/form-data">
                                    <div class="form-row required">
                                        <label asp-for="File" class="label-form-fld">Файл</label>
                                        <input asp-for="StudentExaminationId"
                                               type="hidden"
                                               value="@Model.StudentCourseExaminationId"/>
                                        <input asp-for="File" type="file" class="form-fld">
                                        <div class="border-bottom"></div>
                                        <div class="tooltip-div"></div>
                                    </div>
                                    <div class="form-row btn-row">
                                        @if (!Model.FilesLimitReached)
                                        {
                                            <button class="submit-btn" type="submit">
                                                Качи
                                            </button>
                                        }
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="login-content-item anim-elem top">
                            <div class="login-content-item-wrap">
                                <form>
                                    <div class="form-row required">
                                        <p>Прикачени файлове:</p>
                                    </div>
                                    @foreach (var file in Model.Uploads)
                                    {
                                        <div class="form-row required">
                                            <p>
                                                <a href="@file.Path">@file.FileName</a>
                                            </p>
                                        </div>
                                    }
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}