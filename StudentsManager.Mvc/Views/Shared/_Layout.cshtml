<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Млад Меринджей</title>
    <link rel="stylesheet" href="~/css/site.css"/>
    <link rel="stylesheet" href="~/css/style.css"/>
    <link href="~/css/table.css" rel="stylesheet"/>
    <link href="~/css/loader.min.css" rel="stylesheet"/>
    <script type="text/javascript">
        var _loggedUser = '';
        var _root = './';
        var _controller = 'home';
        var _action = 'index';
        var _lang = 'bg';
        var _langs = '[{"name":"\u0411\u044a\u043b\u0433\u0430\u0440\u0441\u043a\u0438"}]';
        var _timezone_offset = '3';
        var _quesUrl = "@Url.Action("Details", "Click")";
        var _registerUserAnswerUrl = "@Url.Action("RegisterUserAnswer", "Test")";
        var _root_full = '';
        var _url_for = '';
        var _base = '';
    </script>
    <script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js"></script>
    <script>
        WebFont.load({
            google: {
                families: [
                    'Open Sans:100,100i,200,200i,300,300i,400,400i,500,500i,600,600i,700,700i,800,800i,900,900i,cyrillic,cyrillic-ext,latin-ext',
                    'Oswald:400,500,cyrillic,cyrillic-ext,latin-ext'
                ]
            }
        });
    </script>
    @await RenderSectionAsync("Styles", false)
</head>
<body>
<div id="preloader">
    <div class="loader"></div>
</div>
<div id="wrapper" class="wrapper">
    <header id="header" class="header">
        <div class="header-wrap">
            <div class="mobile-menu-row">
                <div class="mobile-logo-container">
                    <a href="./" class="mobile-logo-link">
                        :)
                    </a>
                </div>
                <div class="mobile-menu-container">
                    <div class="mobile-menu-btn-wrap">
                        <button class="menu-btn" id="menu-btn">
                            <span class="lines-wrap">
                                <span class="line line1"></span>
                                <span class="line line2"></span>
                                <span class="line line3"></span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="header-box">
                <div class="header-box-inner">
                    <nav class="nav">
                        <ul class="menu menu-left">
                            <li class="menu-item menu-anim-el">
                                <a asp-controller="Test" asp-action="Index" class="menu-link ">
                                    Тестове
                                </a>
                            </li>
                            <li class="menu-item menu-anim-el">
                                <a href="/Homework" class="menu-link lc">Домашни</a>
                            </li>
                            <li class="menu-item menu-anim-el">
                                <a href="/Profile" class="menu-link">Профил</a>
                            </li>
                        </ul>
                        <h1 class="logo">
                            <a class="logo-link desktop" asp-controller="Home" asp-action="Index">
                                <img src="data:image/png;base64,"
                                     alt="Начало">
                            </a>
                        </h1>
                        <ul class="menu menu-right">
                            <li class="menu-item menu-anim-el">
                                <a href="/Grading" class="menu-link ">
                                    <strong>#Текущ контрол</strong>
                                </a>
                            </li>
                            <li class="menu-item menu-anim-el">
                                <a asp-controller="Click" asp-action="Index" class="menu-link ">
                                    <strong>#Изпитване</strong>
                                </a>
                            </li>
                            <li class="menu-item menu-anim-el">
                                <a asp-action="Index" asp-controller="Forum" class="menu-link ">
                                    Форум
                                </a>
                            </li>
                        </ul>
                    </nav>
                    @await Html.PartialAsync("_LoginPartial")
                </div>
            </div>
        </div>
    </header>

    @RenderBody()

</div>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/test.js"></script>
<script src="~/js/script.js"></script>
<script src="~/js/loader.js"></script>

<script>
    App.init();
</script>
@await RenderSectionAsync("Scripts", false)
</body>
</html>
